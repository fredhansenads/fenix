{
  "name": "santuserp",
  "version": "0.2.0",
  "private": true,
  "description": "ERP web SantusERP da SANTUS",
  "scripts": {
    "start": "node server.js",
    "check": "node scripts/ops-check.js",
    "check:full": "node scripts/ops-check.js --with-smoke",
    "smoke": "node scripts/smoke-test.js",
    "migrate:list": "node scripts/apply-postgres-migrations.js --list",
    "migrate:dry": "node scripts/apply-postgres-migrations.js --dry-run",
    "migrate:apply": "node scripts/apply-postgres-migrations.js --apply",
    "backup": "node scripts/backup-postgres.js",
    "restore:list": "node scripts/restore-postgres.js --list",
    "seed:demo": "node scripts/seed-postgres-demo.js",
    "service:start": "node scripts/santuserp-service.js start",
    "service:stop": "node scripts/santuserp-service.js stop",
    "service:restart": "node scripts/santuserp-service.js restart",
    "service:status": "node scripts/santuserp-service.js status"
  },
  "engines": {
    "node": ">=18"
  }
}
